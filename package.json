{
  "name": "stitch-studio",
  "version": "1.0.0",
  "description": "A remake of pixel to pattern, a crochet pattern generator + pixel art studio.",
  "type": "module",
  "homepage": "https://AugleBoBaugles.github.io/stitch-studio",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "jspdf": "^2.5.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.3.1",
    "vitest": "^1.6.0",
    "jsdom": "^24.1.0",
    "@playwright/test": "^1.45.0",
    "gh-pages": "^6.1.1"
  }
}
